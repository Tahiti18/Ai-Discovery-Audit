---
import MarketingVisual from './MarketingVisual.astro';

interface VisualAsset {
  webp: string;
  webpSrcSet?: string;
  png: string;
  pngSrcSet?: string;
  alt: string;
  caption?: string;
  width: number;
  height: number;
}

interface Metric {
  label: string;
  value: string;
}

interface Props {
  visual: VisualAsset;
  label: string;
  caption?: string;
  eyebrow?: string;
  metrics?: Metric[];
  chips?: string[];
  variant?: 'dark' | 'light' | 'paper';
  sizes?: string;
  imgClass?: string;
  class?: string;
  loading?: 'eager' | 'lazy';
  priority?: boolean;
}

const {
  visual,
  label,
  caption = visual.caption,
  eyebrow,
  metrics = [],
  chips = [],
  variant = 'light',
  sizes = '100vw',
  imgClass = '',
  class: className = '',
  loading = 'lazy',
  priority = false,
} = Astro.props;

const isDark = variant === 'dark';
const isPaper = variant === 'paper';
const shellClass = isDark
  ? 'border-white/10 bg-[#09111c] text-text-inverse shadow-[0_36px_110px_-48px_rgba(13,148,136,0.85)]'
  : isPaper
    ? 'border-border bg-[#fbfaf7] text-text-primary shadow-[0_30px_90px_-58px_rgba(15,23,42,0.5)]'
    : 'border-border bg-bg-surface text-text-primary shadow-[0_30px_90px_-58px_rgba(15,23,42,0.6)]';
const mutedClass = isDark ? 'text-slate-300' : 'text-text-secondary';
const lineClass = isDark ? 'border-white/10' : 'border-border';
---

<figure class={`relative overflow-hidden rounded-[--radius-xl] border ${shellClass} ${className}`}>
  <div
    aria-hidden="true"
    class={`pointer-events-none absolute inset-0 ${isDark ? 'opacity-45' : 'opacity-55'}`}
    style={`background-image: linear-gradient(${isDark ? 'rgba(94,234,212,0.08)' : 'rgba(15,118,110,0.08)'} 1px, transparent 1px), linear-gradient(90deg, ${isDark ? 'rgba(94,234,212,0.08)' : 'rgba(15,118,110,0.08)'} 1px, transparent 1px); background-size: 44px 44px; mask-image: linear-gradient(135deg, black, transparent 72%);`}
  />

  <div class="relative p-3 sm:p-4">
    <div class={`mb-3 flex flex-wrap items-center justify-between gap-3 border-b ${lineClass} pb-3`}>
      <div class="flex items-center gap-2">
        <span class="flex gap-1.5" aria-hidden="true">
          <span class={`h-2 w-2 rounded-full ${isDark ? 'bg-teal-300' : 'bg-accent-teal'}`}></span>
          <span class={`h-2 w-2 rounded-full ${isDark ? 'bg-slate-500' : 'bg-border'}`}></span>
          <span class={`h-2 w-2 rounded-full ${isDark ? 'bg-slate-600' : 'bg-border'}`}></span>
        </span>
        <span class={`font-mono text-[11px] uppercase tracking-[0.18em] ${mutedClass}`}>{label}</span>
      </div>
      {eyebrow && (
        <span class={`rounded-full px-2.5 py-1 font-mono text-[10px] uppercase tracking-[0.16em] ${isDark ? 'bg-white/10 text-teal-100' : 'bg-accent-teal/10 text-accent-teal'}`}>
          {eyebrow}
        </span>
      )}
    </div>

    <div class="relative overflow-hidden rounded-[--radius-lg]">
      <MarketingVisual
        webp={visual.webp}
        webpSrcSet={visual.webpSrcSet}
        png={visual.png}
        pngSrcSet={visual.pngSrcSet}
        alt={visual.alt}
        width={visual.width}
        height={visual.height}
        sizes={sizes}
        loading={loading}
        priority={priority}
        imgClass={imgClass}
      />
      {metrics.length > 0 && (
        <div class="pointer-events-none absolute inset-x-3 bottom-3 grid gap-2 sm:grid-cols-3">
          {metrics.map((metric) => (
            <div class={`backdrop-blur-xl ${isDark ? 'border-white/10 bg-black/35' : 'border-white/70 bg-white/80'} rounded-[--radius-md] border px-3 py-2 shadow-[0_14px_40px_-26px_rgba(15,23,42,0.65)]`}>
              <p class={`font-mono text-[10px] uppercase tracking-[0.14em] ${mutedClass}`}>{metric.label}</p>
              <p class={`mt-1 text-sm font-semibold ${isDark ? 'text-white' : 'text-text-primary'}`}>{metric.value}</p>
            </div>
          ))}
        </div>
      )}
    </div>

    {(caption || chips.length > 0) && (
      <figcaption class={`mt-3 flex flex-col gap-3 border-t ${lineClass} pt-3 sm:flex-row sm:items-start sm:justify-between`}>
        {caption && (
          <p class={`max-w-2xl text-xs leading-relaxed ${mutedClass}`}>{caption}</p>
        )}
        {chips.length > 0 && (
          <div class="flex flex-wrap gap-2 sm:justify-end">
            {chips.map((chip) => (
              <span class={`rounded-full border px-2.5 py-1 font-mono text-[10px] uppercase tracking-[0.14em] ${isDark ? 'border-white/10 bg-white/5 text-teal-100' : 'border-border bg-bg-subtle text-text-secondary'}`}>
                {chip}
              </span>
            ))}
          </div>
        )}
      </figcaption>
    )}
  </div>
</figure>
