---
import Shell from '../components/Shell.astro';
import ResearchCard from '../components/content/ResearchCard.astro';
import VisualStage from '../components/VisualStage.astro';
import { marketingVisuals } from '../lib/marketingVisuals';
import { researchSources, researchClosing } from '../lib/researchContent';
---

<Shell title="GEO Research — Papers Behind AI Search Visibility" description="Peer-reviewed papers, benchmarks, and industry reports behind AI search visibility scoring — the research foundation for generative engine optimization." canonical="https://geoready.dev/research/">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 py-10 md:py-16">
    {/* Header */}
    <header class="mb-14 overflow-hidden rounded-[--radius-2xl] border border-border bg-bg-surface md:mb-20">
      <div class="grid lg:grid-cols-[minmax(0,0.88fr)_minmax(420px,0.82fr)]">
      <div class="p-6 md:p-10 lg:p-12">
        <div class="flex items-center gap-2 text-[10px] font-mono text-text-muted uppercase tracking-wider">
          <span>GEO Optimizer</span>
          <span class="w-1 h-1 rounded-full bg-text-muted" />
          <span>Research</span>
        </div>

        <h1 class="mt-4 max-w-3xl font-display text-4xl md:text-5xl font-bold text-text-primary leading-tight tracking-tight">
          The research foundation behind AI visibility scoring.
        </h1>

        <p class="mt-5 text-base md:text-lg text-text-secondary leading-relaxed max-w-2xl">
          Built on peer-reviewed science, not marketing claims. Every signal in GEO Optimizer is traceable to a published source.
        </p>
        <p class="mt-2 text-xs text-text-muted font-mono">Last updated: May 2026</p>

        <div class="mt-8 grid gap-3 sm:grid-cols-3">
          {[
            ['Papers', 'Research patterns that shape the scoring model.'],
            ['Benchmarks', 'Evidence from retrieval and answer behavior.'],
            ['Rules', 'Auditable checks that map evidence to action.'],
          ].map(([label, text]) => (
            <div class="border-l border-accent-teal/30 pl-4">
              <p class="font-mono text-[11px] uppercase tracking-[0.16em] text-accent-teal">{label}</p>
              <p class="mt-1 text-sm leading-relaxed text-text-secondary">{text}</p>
            </div>
          ))}
        </div>

        <p class="mt-8 text-sm text-text-secondary">
          To turn this research into practice, see the
          <a href="/guides/ai-visibility-checklist/" class="text-accent-teal hover:underline">AI visibility checklist</a>,
          the <a href="/guides/geo-vs-seo/" class="text-accent-teal hover:underline">GEO vs SEO comparison</a>, and the
          <a href="/guides/llms-txt-wordpress/" class="text-accent-teal hover:underline">llms.txt implementation guide</a>.
        </p>
      </div>

      <div class="border-t border-border bg-bg-subtle p-4 lg:border-l lg:border-t-0">
        <VisualStage
          visual={marketingVisuals.discoveryStack}
          variant="paper"
          label="Evidence stack"
          eyebrow="Methodology"
          sizes="(min-width: 1024px) 38vw, 100vw"
          loading="eager"
          priority
          imgClass="aspect-[16/9] object-cover"
          metrics={[
            { label: 'Inputs', value: 'Papers' },
            { label: 'Signals', value: '8 categories' },
            { label: 'Output', value: 'Audit rules' },
          ]}
          chips={['Peer-reviewed', 'Benchmarks', 'Internal analysis']}
        />
      </div>
      </div>
    </header>

    {/* Type filter legend */}
    <div class="mb-8 flex flex-wrap items-center gap-3 rounded-[--radius-lg] border border-border bg-bg-surface px-4 py-3 text-[11px] font-mono text-text-muted">
      <span class="inline-flex items-center gap-1.5">
        <span class="w-2 h-2 rounded-full bg-accent-teal" />
        Peer-reviewed paper
      </span>
      <span class="inline-flex items-center gap-1.5">
        <span class="w-2 h-2 rounded-full bg-accent-warning" />
        Benchmark
      </span>
      <span class="inline-flex items-center gap-1.5">
        <span class="w-2 h-2 rounded-full bg-text-muted" />
        Industry report
      </span>
      <span class="inline-flex items-center gap-1.5">
        <span class="w-2 h-2 rounded-full bg-accent-success" />
        Internal analysis
      </span>
    </div>

    <div class="mb-8 flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
      <div>
        <p class="font-mono text-[11px] uppercase tracking-[0.18em] text-accent-teal">Traceable scoring</p>
        <h2 class="mt-2 text-xl md:text-2xl font-bold text-text-primary">Sources and findings</h2>
      </div>
      <a href="/manifesto/" class="text-sm text-accent-teal hover:text-accent-teal-dark transition-colors">
        Read the manifesto
      </a>
    </div>

    <div class="space-y-6">
      {researchSources.map((source) => (
        <ResearchCard source={source} />
      ))}
    </div>

    {/* Closing statement */}
    <div class="mt-14 md:mt-20 max-w-2xl">
      <blockquote class="pl-5 border-l-2 border-accent-teal" cite="https://geoready.dev/research/">
        <p class="text-sm font-medium text-text-primary italic leading-relaxed">
          {researchClosing.statement}
        </p>
      </blockquote>
    </div>
  </div>

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "name": "GEO Research Foundation",
    "url": "https://geoready.dev/research/",
    "description": "Peer-reviewed papers, benchmarks, and industry reports behind AI search visibility scoring — the research foundation for generative engine optimization.",
    "author": {
      "@type": "Organization",
      "name": "Auriti Labs",
      "url": "https://github.com/Auriti-Labs"
    },
    "publisher": {
      "@type": "Organization",
      "name": "Auriti Labs",
      "url": "https://github.com/Auriti-Labs"
    },
    "datePublished": "2026-05-12",
    "dateModified": "2026-05-26",
    "mainEntity": {
      "@type": "ItemList",
      "itemListElement": researchSources.map((s, i) => ({
        "@type": "ListItem",
        "position": i + 1,
        "name": s.title,
        "description": s.finding
      }))
    }
  })} />
</Shell>
