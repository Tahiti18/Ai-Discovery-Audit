---
import Shell from '../components/Shell.astro';
import AuditForm from '../components/AuditForm';
import StatsBar from '../components/StatsBar';
import VisualStage from '../components/VisualStage.astro';
import { marketingVisuals } from '../lib/marketingVisuals';

const trustCards = [
  {
    title: 'Open source (MIT)',
    desc: 'Full methodology, scoring weights, and source code on GitHub. No proprietary scoring.',
    link: { label: 'View on GitHub', href: 'https://github.com/Auriti-Labs/geo-optimizer-skill' },
  },
  {
    title: 'Research-backed',
    desc: 'Scoring grounded in Princeton KDD 2024 and AutoGEO ICLR 2026 research on AI search retrieval.',
    link: { label: 'Read the research', href: '/research/' },
  },
  {
    title: 'Auditable scoring',
    desc: 'Every signal is traceable to a published rule. Score breakdowns show per-category contributions.',
    link: null,
  },
  {
    title: 'Machine-readable output',
    desc: 'JSON format designed for CI/CD pipelines, integrations, and the GeoReady platform API.',
    link: null,
  },
];

const actions = [
  {
    label: 'Run a free audit',
    desc: 'Enter any public URL above — no account required.',
    href: '#audit-form',
    badge: 'Available now',
    badgeStyle: 'bg-accent-success/10 text-accent-success',
  },
  {
    label: 'Use the open-source CLI',
    desc: 'pip install geo-optimizer-skill — audit, access simulation, crawler log analysis. MIT licensed.',
    href: 'https://github.com/Auriti-Labs/geo-optimizer-skill',
    badge: 'Free forever',
    badgeStyle: 'bg-accent-success/10 text-accent-success',
  },
  {
    label: 'Read the research',
    desc: 'Princeton KDD 2024 and AutoGEO ICLR 2026 behind the scoring methodology.',
    href: '/research/',
    badge: 'Documentation',
    badgeStyle: 'bg-bg-subtle text-text-muted border border-border',
  },
  {
    label: 'View plans',
    desc: 'Pro monitoring, history, and alerts. Founding price, locked for life.',
    href: '/pricing/',
    badge: 'Live now',
    badgeStyle: 'bg-accent-teal/10 text-accent-teal',
  },
];

const faqs = [
  {
    q: 'What is Generative Engine Optimization?',
    a: 'GEO is the practice of making websites discoverable, readable, and citable by AI search engines such as ChatGPT, Perplexity, Claude, and Gemini. It focuses on structured data, content hierarchy, and technical signals that AI crawlers prioritize.',
  },
  {
    q: 'What does GEO Optimizer check?',
    a: 'The tool audits 8 categories: robots.txt, llms.txt, JSON-LD schema, meta tags, content quality, technical signals, AI discovery paths, and brand entity signals. It also detects prompt injection patterns and negative signals. The CLI additionally offers Agent Access Audit (bot vs browser access simulation via `geo access`) and AI Crawler Activity Analytics (server log parsing via `geo logs`).',
  },
  {
    q: 'How is GEO different from traditional SEO?',
    a: 'Traditional SEO optimizes for keyword rankings and backlinks in conventional search engines. GEO optimizes for AI citation signals: structured data, clear content architecture, AI crawler permissions, and self-contained answer blocks. The two complement rather than replace each other.',
  },
  {
    q: 'Is the Pro plan available now?',
    a: 'Yes. Pick a plan and your account activates immediately. No sales call, no waitlist.',
  },
  {
    q: 'Is GEO Optimizer open source?',
    a: 'Yes. The core toolkit is MIT licensed. Source code, scoring weights, and methodology are publicly available on GitHub. The CLI and the web tool remain free.',
  },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(f => ({
    "@type": "Question",
    "name": f.q,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": f.a
    }
  }))
};
---

<script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
<Shell
  title="Free AI SEO & GEO Audit — GeoReady"
  description="Run a free AI SEO and GEO audit. See how ChatGPT, Perplexity, Claude and Gemini can crawl, understand and cite your site — and what to fix."
  canonical="https://geoready.dev/"
>
  {/* Hero */}
  <section id="audit-form" data-hero-bleed class="relative overflow-hidden bg-bg-dark text-text-inverse">
    <div
      aria-hidden="true"
      class="absolute inset-0 opacity-45"
      style="background-image: radial-gradient(circle at 76% 24%, rgba(94,234,212,0.16), transparent 34%), linear-gradient(rgba(148,163,184,0.08) 1px, transparent 1px), linear-gradient(90deg, rgba(148,163,184,0.08) 1px, transparent 1px); background-size: auto, 56px 56px, 56px 56px;"
    />
    <div class="relative max-w-7xl mx-auto px-6 py-20 md:py-28">
      <div class="grid items-center gap-10 lg:grid-cols-[minmax(0,0.82fr)_minmax(520px,1fr)]">
        <div class="max-w-3xl">
          <p class="mb-5 inline-flex rounded-full border border-white/10 bg-white/5 px-3 py-1 font-mono text-[11px] uppercase tracking-[0.18em] text-teal-100">
            AI visibility audit
          </p>
          <h1 class="text-4xl md:text-6xl font-bold tracking-tight leading-tight">
            Is your website visible to AI search engines?
          </h1>
          <p class="mt-6 text-lg md:text-xl text-text-muted leading-relaxed max-w-2xl">
            AI SEO is about being visible in AI search. GeoReady audits whether a website can be crawled,
            understood, and cited by AI answer engines like ChatGPT, Perplexity, Claude, and Gemini.
            Get a 0–100 GEO score across 8 signal categories — free, no account required.
          </p>

          <div class="mt-8 grid max-w-2xl grid-cols-1 gap-3 sm:grid-cols-3">
            <div class="border-l border-teal-300/40 pl-4">
              <p class="font-mono text-[11px] uppercase tracking-[0.16em] text-teal-100">Access</p>
              <p class="mt-1 text-sm text-text-muted">AI crawler rules and fetchability.</p>
            </div>
            <div class="border-l border-teal-300/40 pl-4">
              <p class="font-mono text-[11px] uppercase tracking-[0.16em] text-teal-100">Structure</p>
              <p class="mt-1 text-sm text-text-muted">Schema, llms.txt, and page hierarchy.</p>
            </div>
            <div class="border-l border-teal-300/40 pl-4">
              <p class="font-mono text-[11px] uppercase tracking-[0.16em] text-teal-100">Citation</p>
              <p class="mt-1 text-sm text-text-muted">Recommendations ranked by impact.</p>
            </div>
          </div>

          <div class="mt-10">
            <AuditForm client:load />
          </div>

          <StatsBar client:load />

          <div class="mt-6 flex flex-wrap items-center gap-4 text-sm">
            <a href="/pricing/" data-cta="home_hero_view_pricing" class="text-text-muted hover:text-text-inverse transition-colors">View pricing</a>
            <span class="text-text-muted/40">·</span>
            <a href="/pricing/" data-cta="home_hero_see_plans" class="text-text-muted hover:text-text-inverse transition-colors">GeoReady Pro — see plans</a>
          </div>
        </div>

        <div class="relative lg:-mr-10">
          <div aria-hidden="true" class="absolute -inset-6 rounded-[--radius-2xl] border border-teal-300/10 bg-teal-300/[0.03] blur-3xl"></div>
          <VisualStage
            visual={marketingVisuals.commandCenter}
            variant="dark"
            label="Audit command center"
            eyebrow="Live surface"
            sizes="(min-width: 1024px) 48vw, 100vw"
            loading="eager"
            priority
            imgClass="aspect-[16/9] object-cover"
            metrics={[
              { label: 'Score', value: '0-100 GEO' },
              { label: 'Signals', value: '8 categories' },
              { label: 'Output', value: 'JSON + report' },
            ]}
            chips={['Crawler access', 'Citation graph', 'Impact fixes']}
            class="relative"
          />
        </div>
      </div>
    </div>
  </section>

  {/* What is AI search visibility */}
  <section class="relative overflow-hidden border-b border-border bg-bg-base">
    <div class="max-w-7xl mx-auto px-6 py-20 md:py-24">
      <div class="grid gap-12 lg:grid-cols-[minmax(0,0.78fr)_minmax(420px,0.82fr)] lg:items-center">
        <div class="max-w-3xl">
          <p class="font-mono text-[11px] uppercase tracking-[0.18em] text-accent-teal">Category map</p>
          <h2 class="mt-3 text-3xl md:text-5xl font-bold text-text-primary tracking-tight">AI SEO is not a checklist. It is a retrieval path.</h2>
          <p class="mt-5 text-lg text-text-secondary leading-relaxed">
            Traditional SEO asks whether a page can rank. AI SEO asks whether an answer engine can reach it, parse it, trust it, and cite it.
          </p>

          <div class="mt-8 space-y-4">
            {[
              ['01', 'Access', 'Crawler permissions, HTTP behavior, and server-rendered content decide whether AI systems can reach the page.'],
              ['02', 'Meaning', 'llms.txt, schema, headings, and entity consistency help the model understand what the page is about.'],
              ['03', 'Citation', 'Self-contained answers and factual density make the page easier to quote inside generated responses.'],
            ].map(([num, title, text]) => (
              <div class="grid grid-cols-[44px_minmax(0,1fr)] gap-4 border-l border-border bg-bg-surface/60 p-4">
                <span class="font-mono text-xs text-accent-teal">{num}</span>
                <div>
                  <h3 class="font-display text-base font-semibold text-text-primary">{title}</h3>
                  <p class="mt-1 text-sm leading-relaxed text-text-secondary">{text}</p>
                </div>
              </div>
            ))}
          </div>

          <div class="mt-7 flex flex-wrap items-center gap-4 text-sm">
            <a href="/research/" class="text-accent-teal hover:text-accent-teal-dark transition-colors">Read the research</a>
            <span class="text-text-muted">·</span>
            <a href="/guides/" class="text-accent-teal hover:text-accent-teal-dark transition-colors">AI visibility guides</a>
            <span class="text-text-muted">·</span>
            <a href="/report/demo/" class="text-accent-teal hover:text-accent-teal-dark transition-colors">View a demo report</a>
          </div>
        </div>

        <VisualStage
          visual={marketingVisuals.discoveryStack}
          variant="paper"
          label="Discovery model"
          eyebrow="Access to citation"
          sizes="(min-width: 1024px) 42vw, 100vw"
          imgClass="aspect-[16/9] object-cover"
          metrics={[
            { label: 'Layer 1', value: 'Crawler access' },
            { label: 'Layer 2', value: 'Entity clarity' },
            { label: 'Layer 3', value: 'Citation output' },
          ]}
          chips={['robots.txt', 'llms.txt', 'Schema']}
        />
      </div>
    </div>
  </section>

  {/* How it works */}
  <section class="max-w-7xl mx-auto px-6 py-16">
    <div class="max-w-3xl">
      <h2 class="text-2xl md:text-3xl font-bold text-text-primary">How GEO Optimizer works</h2>
      <div class="mt-8 space-y-8">
        <div>
          <h3 class="text-lg font-semibold text-text-primary">1. Enter a URL</h3>
          <p class="mt-2 text-text-secondary leading-relaxed">
            Submit any public website address. The tool resolves and validates the URL,
            then fetches the page source for analysis.
          </p>
        </div>
        <div>
          <h3 class="text-lg font-semibold text-text-primary">2. Get a GEO score</h3>
          <p class="mt-2 text-text-secondary leading-relaxed">
            The audit evaluates 8 signal categories — robots.txt, llms.txt, schema, meta tags,
            content quality, technical signals, AI discovery, and brand entity — producing a
            0–100 score with per-category breakdown.
          </p>
        </div>
        <div>
          <h3 class="text-lg font-semibold text-text-primary">3. Apply prioritized fixes</h3>
          <p class="mt-2 text-text-secondary leading-relaxed">
            Each finding is ranked by impact and assigned a severity level. The report includes
            actionable recommendations with specific file changes and schema additions.
          </p>
        </div>
      </div>
    </div>
  </section>

  {/* Trust cards */}
  <section class="max-w-7xl mx-auto px-6 py-20">
    <h2 class="text-xl md:text-2xl font-bold text-text-primary mb-8">Why trust this tool</h2>
    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
      {trustCards.map((c) => (
        <div class="p-6 rounded-[--radius-lg] border border-border bg-bg-surface hover:border-accent-teal/40 transition-colors flex flex-col">
          <h3 class="font-display text-base font-semibold text-text-primary">{c.title}</h3>
          <p class="mt-2 text-sm text-text-secondary leading-relaxed flex-1">{c.desc}</p>
          {c.link && (
            <a
              href={c.link.href}
              target={c.link.href.startsWith('http') ? '_blank' : undefined}
              rel={c.link.href.startsWith('http') ? 'noopener' : undefined}
              class="mt-4 text-xs font-mono text-accent-teal hover:underline"
            >
              {c.link.label} →
            </a>
          )}
        </div>
      ))}
    </div>
  </section>

  {/* What you can do today */}
  <section class="max-w-7xl mx-auto px-6 py-16 border-t border-border">
    <h2 class="text-xl md:text-2xl font-bold text-text-primary mb-8">What you can do today</h2>
    <div class="grid sm:grid-cols-2 gap-4">
      {actions.map((a) => (
        <a
          href={a.href}
          target={a.href.startsWith('http') ? '_blank' : undefined}
          rel={a.href.startsWith('http') ? 'noopener' : undefined}
          class="group flex items-start gap-4 p-5 rounded-[--radius-lg] border border-border bg-bg-surface hover:border-accent-teal/40 transition-colors"
        >
          <div class="flex-1 min-w-0">
            <div class="flex items-center gap-2 mb-1 flex-wrap">
              <p class="text-sm font-semibold text-text-primary group-hover:text-accent-teal transition-colors">{a.label}</p>
              <span class={`text-[10px] font-mono uppercase tracking-wider px-1.5 py-0.5 rounded-full ${a.badgeStyle}`}>{a.badge}</span>
            </div>
            <p class="text-sm text-text-secondary leading-relaxed">{a.desc}</p>
          </div>
          <svg class="mt-0.5 w-4 h-4 shrink-0 text-text-muted group-hover:text-accent-teal transition-colors" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
          </svg>
        </a>
      ))}
    </div>
  </section>

  {/* From audit to monitoring */}
  <section class="relative overflow-hidden bg-bg-dark text-text-inverse">
    <div class="max-w-7xl mx-auto px-6 py-20 md:py-24">
      <div class="grid gap-10 lg:grid-cols-[minmax(420px,0.92fr)_minmax(0,0.72fr)] lg:items-center">
        <VisualStage
          visual={marketingVisuals.monitoring}
          variant="dark"
          label="Monitoring room"
          eyebrow="Continuous signal"
          sizes="(min-width: 1024px) 52vw, 100vw"
          imgClass="aspect-[4/3] object-cover object-top"
          metrics={[
            { label: 'History', value: 'Weekly trend' },
            { label: 'Alert', value: 'Score drop' },
            { label: 'Portfolio', value: 'Domains' },
          ]}
          chips={['Score history', 'Regression alerts', 'Snapshots']}
        />

        <div>
          <p class="font-mono text-[11px] uppercase tracking-[0.18em] text-teal-100">From audit to monitoring</p>
          <h2 class="mt-3 text-3xl md:text-5xl font-bold tracking-tight">
            One audit gives the baseline. Monitoring tells you when the baseline moves.
          </h2>
          <p class="mt-5 text-base leading-relaxed text-text-muted">
            The free audit is a point-in-time diagnosis. GeoReady Pro turns the same scoring engine into an ongoing signal for teams and client work.
          </p>

          <div class="mt-8 grid gap-3">
            <div class="border border-white/10 bg-white/[0.04] p-5">
              <div class="flex items-center justify-between gap-3">
                <h3 class="font-display text-base font-semibold">Free audit</h3>
                <span class="font-mono text-[10px] uppercase tracking-[0.16em] text-teal-100">Available</span>
              </div>
              <p class="mt-2 text-sm leading-relaxed text-text-muted">
                GEO score, top recommendations, and a fast read on whether a URL is crawlable and understandable.
              </p>
            </div>
            <div class="border border-teal-300/30 bg-teal-300/[0.06] p-5">
              <div class="flex items-center justify-between gap-3">
                <h3 class="font-display text-base font-semibold">GeoReady Pro</h3>
                <span class="font-mono text-[10px] uppercase tracking-[0.16em] text-teal-100">Live</span>
              </div>
              <p class="mt-2 text-sm leading-relaxed text-text-muted">
                Weekly monitoring, report history, regression alerts, PDF export, and API access.
              </p>
              <a
                href="https://app.geoready.dev/signup?plan=pro"
                data-plan-id="pro"
                data-plan-name="Pro"
                data-plan-price="$19"
                data-plan-period="/month"
                data-plan-currency="USD"
                data-cta-location="home_monitoring_section"
                class="mt-4 inline-flex text-sm font-semibold text-teal-100 underline underline-offset-4"
              >
                Start with Pro
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* FAQ */}
  <section class="max-w-7xl mx-auto px-6 py-16 border-t border-border">
    <div class="max-w-3xl">
      <h2 class="text-2xl md:text-3xl font-bold text-text-primary mb-8">Frequently asked questions</h2>
      <div class="space-y-6">
        {faqs.map((faq) => (
          <div>
            <h3 class="text-base font-semibold text-text-primary">{faq.q}</h3>
            <p class="mt-2 text-sm text-text-secondary leading-relaxed">{faq.a}</p>
          </div>
        ))}
        <div>
          <h3 class="text-base font-semibold text-text-primary">Does the audit store submitted URLs?</h3>
          <p class="mt-2 text-sm text-text-secondary leading-relaxed">
            URLs are processed in real time. No persistent storage of submitted URLs is declared unless
            explicitly configured in the backend. See the <a href="/privacy/" class="text-accent-teal hover:underline">Privacy Policy</a> for details.
          </p>
        </div>
      </div>
    </div>
  </section>

  {/* Final CTA */}
  <section class="max-w-7xl mx-auto px-6 pb-20">
    <div class="overflow-hidden border border-border bg-bg-surface">
      <div class="grid lg:grid-cols-[minmax(0,0.82fr)_minmax(420px,0.78fr)]">
        <div class="p-8 md:p-12 lg:p-14">
          <p class="font-mono text-[11px] uppercase tracking-[0.18em] text-accent-teal">Open scoring, practical output</p>
          <h2 class="mt-3 text-3xl md:text-5xl font-bold text-text-primary tracking-tight">
            AI search is already deciding which sites get cited.
          </h2>
          <p class="mt-5 max-w-2xl text-text-secondary leading-relaxed">
            The signals are documented, the research is published, and the tool is free.
            GEO Optimizer exists to make AI visibility auditable and accessible to every developer.
          </p>
          <div class="mt-7 flex flex-wrap gap-3">
            <a
              href="#audit-form"
              class="inline-block py-2.5 px-6 rounded-[--radius-md] bg-accent-teal text-white text-sm font-semibold hover:bg-accent-teal-dark transition-colors"
            >
              Start free audit
            </a>
            <a
              href="/pricing/"
              data-cta="home_final_pick_plan"
              class="inline-block py-2.5 px-6 rounded-[--radius-md] border border-border text-sm font-semibold text-text-primary hover:bg-bg-subtle transition-colors"
            >
              Start free or pick a plan
            </a>
          </div>
        </div>
        <div class="border-t border-border bg-bg-subtle p-4 lg:border-l lg:border-t-0">
          <VisualStage
            visual={marketingVisuals.clientReport}
            variant="paper"
            label="Report package"
            eyebrow="Client output"
            sizes="(min-width: 1024px) 36vw, 100vw"
            imgClass="aspect-[4/3] object-cover"
            chips={['Score breakdown', 'Recommendations', 'PDF export']}
          />
        </div>
      </div>
    </div>
  </section>
</Shell>
