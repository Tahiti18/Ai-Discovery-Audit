---
import Shell from '../components/Shell.astro';
import AuditForm from '../components/AuditForm';

const stats = [
  { label: 'stars', value: '407', icon: 'star' },
  { label: 'downloads/mo', value: '4.0k', icon: 'box' },
  { label: 'audits', value: '1.6k', icon: 'search' },
];

const features = [
  {
    title: 'Auditability',
    desc: 'Every signal is scored against published research. No black boxes.',
  },
  {
    title: 'Scientific Foundation',
    desc: 'Built on Princeton KDD 2024, AutoGEO ICLR 2026, and SE Ranking 2025.',
  },
  {
    title: 'Open Source',
    desc: 'MIT licensed. Full transparency in methodology and scoring weights.',
  },
  {
    title: 'Precision',
    desc: '47 citability methods, 8 audit categories, 100-point scoring system.',
  },
];
---

<Shell
  title="GEO Optimizer — AI Search Visibility Audit"
  description="Audit your website's AI search visibility. GEO Optimizer scores your site across 8 categories with actionable fixes for ChatGPT, Perplexity, Claude, and Gemini."
>
  <section class="bg-bg-dark text-text-inverse">
    <div class="max-w-7xl mx-auto px-6 py-20 md:py-28">
      <div class="max-w-3xl">
        <h1 class="text-4xl md:text-6xl font-bold tracking-tight leading-tight">
          Audit your website's visibility to AI search engines
        </h1>
        <p class="mt-6 text-lg md:text-xl text-text-muted leading-relaxed max-w-2xl">
          GEO Optimizer scores your site across 8 categories so you know exactly how discoverable you are to ChatGPT, Perplexity, Claude, and Gemini.
        </p>

        <div class="mt-10">
          <AuditForm client:load />
        </div>

        <div class="mt-8 flex flex-wrap items-center gap-6">
          {stats.map((s) => (
            <div class="flex items-center gap-2 text-sm">
              <span class="font-mono text-text-muted">{s.icon}</span>
              <span class="font-mono font-semibold">{s.value}</span>
              <span class="text-text-muted">{s.label}</span>
            </div>
          ))}
        </div>
        <p class="mt-2 text-xs text-text-muted font-mono">Snapshot: May 2026 — not live data</p>
      </div>
    </div>
  </section>

  <section class="max-w-7xl mx-auto px-6 py-16">
    <div class="max-w-3xl">
      <h2 class="text-2xl md:text-3xl font-bold text-text-primary">What is Generative Engine Optimization?</h2>
      <p class="mt-4 text-text-secondary leading-relaxed">
        Generative Engine Optimization (GEO) is the practice of making websites
        discoverable, readable, and citable by AI search engines such as ChatGPT,
        Perplexity, Claude, and Gemini. Unlike traditional SEO, which optimizes
        for keyword rankings and backlinks, GEO focuses on signals that AI crawlers
        prioritize when selecting content to cite: structured data markup,
        clear content hierarchy, technical accessibility, and trust signals.
      </p>
      <p class="mt-4 text-text-secondary leading-relaxed">
        Key GEO signals include a well-configured <code class="font-mono text-sm bg-bg-subtle px-1 rounded">robots.txt</code> that allows
        AI crawlers, an <code class="font-mono text-sm bg-bg-subtle px-1 rounded">llms.txt</code> file that guides crawlers through your content,
        complete JSON-LD schema for entity disambiguation, and self-contained answer
        blocks that AI models can quote directly. GEO Optimizer audits every one of
        these signals and produces a 0-100 score with specific, research-backed
        recommendations.
      </p>
      <div class="mt-6 flex flex-wrap items-center gap-4 text-sm">
        <a href="/research" class="text-accent-teal hover:text-accent-teal-dark transition-colors">Read the research</a>
        <span class="text-text-muted">·</span>
        <a href="/manifesto" class="text-accent-teal hover:text-accent-teal-dark transition-colors">Read the manifesto</a>
        <span class="text-text-muted">·</span>
        <a href="/report/demo" class="text-accent-teal hover:text-accent-teal-dark transition-colors">View a demo report</a>
      </div>
    </div>
  </section>

  <section class="max-w-7xl mx-auto px-6 py-16">
    <div class="max-w-3xl">
      <h2 class="text-2xl md:text-3xl font-bold text-text-primary">How GEO Optimizer works</h2>
      <div class="mt-8 space-y-8">
        <div>
          <h3 class="text-lg font-semibold text-text-primary">1. Enter a URL</h3>
          <p class="mt-2 text-text-secondary leading-relaxed">
            Submit any public website address. The tool resolves and validates the URL,
            then fetches the page source for analysis.
          </p>
        </div>
        <div>
          <h3 class="text-lg font-semibold text-text-primary">2. Get a GEO score</h3>
          <p class="mt-2 text-text-secondary leading-relaxed">
            The audit evaluates 8 signal categories — robots.txt, llms.txt, schema, meta tags,
            content quality, technical signals, AI discovery, and brand entity — producing a
            0-100 score with per-category breakdown.
          </p>
        </div>
        <div>
          <h3 class="text-lg font-semibold text-text-primary">3. Apply prioritized fixes</h3>
          <p class="mt-2 text-text-secondary leading-relaxed">
            Each finding is ranked by impact and assigned a severity level. The report includes
            actionable recommendations with specific file changes and schema additions.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="max-w-7xl mx-auto px-6 py-16">
    <div class="max-w-3xl">
      <h2 class="text-2xl md:text-3xl font-bold text-text-primary">Preview the audit report</h2>
      <p class="mt-4 text-text-secondary leading-relaxed">
        A GEO Optimizer report contains the GEO score, category breakdown, technical signal status,
        citability analysis, and prioritized recommendations. The demo report below shows a representative
        example. Real reports are generated on demand for any submitted URL.
      </p>
      <a
        href="/report/demo"
        class="inline-flex items-center gap-2 mt-6 text-sm font-medium text-accent-teal hover:text-accent-teal-dark transition-colors"
      >
        View demo report
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M5 12h14"/>
          <path d="m12 5 7 7-7 7"/>
        </svg>
      </a>
    </div>
  </section>

  <section class="max-w-7xl mx-auto px-6 py-20">
    <h2 class="text-xl md:text-2xl font-bold text-text-primary mb-8">What GEO Optimizer checks</h2>
    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
      {features.map((f) => (
        <div class="p-6 rounded-xl border border-border bg-bg-surface hover:border-accent-teal/40 transition-colors">
          <h3 class="font-display text-base font-semibold">{f.title}</h3>
          <p class="mt-2 text-sm text-text-secondary leading-relaxed">{f.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="max-w-7xl mx-auto px-6 py-16">
    <div class="max-w-3xl">
      <h2 class="text-2xl md:text-3xl font-bold text-text-primary mb-8">Frequently asked questions</h2>
      <div class="space-y-6">
        <div>
          <h3 class="text-base font-semibold text-text-primary">What is Generative Engine Optimization?</h3>
          <p class="mt-2 text-sm text-text-secondary leading-relaxed">
            GEO is the practice of making websites discoverable, readable, and citable by AI search engines such as ChatGPT, Perplexity, Claude, and Gemini. It focuses on structured data, content hierarchy, and technical signals that AI crawlers prioritize.
          </p>
        </div>
        <div>
          <h3 class="text-base font-semibold text-text-primary">How is GEO different from traditional SEO?</h3>
          <p class="mt-2 text-sm text-text-secondary leading-relaxed">
            Traditional SEO optimizes for keyword rankings and backlinks in conventional search engines. GEO optimizes for AI citation signals: structured data, clear content architecture, AI crawler permissions, and self-contained answer blocks.
          </p>
        </div>
        <div>
          <h3 class="text-base font-semibold text-text-primary">What does GEO Optimizer check?</h3>
          <p class="mt-2 text-sm text-text-secondary leading-relaxed">
            The tool audits 8 categories: robots.txt, llms.txt, JSON-LD schema, meta tags, content quality, technical signals, AI discovery paths, and brand entity signals. It also detects prompt injection patterns and negative signals.
          </p>
        </div>
        <div>
          <h3 class="text-base font-semibold text-text-primary">Does GEO Optimizer replace SEO tools?</h3>
          <p class="mt-2 text-sm text-text-secondary leading-relaxed">
            No. GEO Optimizer complements traditional SEO tools by adding an AI-specific visibility layer. It does not replace keyword research, backlink analysis, or rank tracking.
          </p>
        </div>
        <div>
          <h3 class="text-base font-semibold text-text-primary">Is GEO Optimizer open source?</h3>
          <p class="mt-2 text-sm text-text-secondary leading-relaxed">
            Yes. The core toolkit is MIT licensed. Source code, scoring weights, and methodology are publicly available on GitHub.
          </p>
        </div>
        <div>
          <h3 class="text-base font-semibold text-text-primary">Does the audit store submitted URLs?</h3>
          <p class="mt-2 text-sm text-text-secondary leading-relaxed">
            URLs are processed in real time. No persistent storage of submitted URLs is declared unless explicitly configured in the backend. See the <a href="/privacy" class="text-accent-teal hover:underline">Privacy Policy</a> for details.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="max-w-7xl mx-auto px-6 pb-20">
    <div class="p-8 md:p-12 rounded-2xl border border-border bg-bg-surface">
      <div class="max-w-3xl">
        <h2 class="text-2xl md:text-3xl font-bold">Why this tool exists</h2>
        <p class="mt-4 text-text-secondary leading-relaxed">
          AI search is already deciding which websites get cited and which do not.
          The signals are documented, the research is published, but most of the web has no idea.
          GEO Optimizer exists to make AI visibility auditable, transparent, and accessible to every developer,
          not just teams with enterprise budgets.
        </p>
        <a
          href="/manifesto"
          class="inline-flex items-center gap-2 mt-6 text-sm font-medium text-accent-teal hover:text-accent-teal-dark transition-colors"
        >
          Read the full manifesto
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14"/>
            <path d="m12 5 7 7-7 7"/>
          </svg>
        </a>
      </div>
    </div>
  </section>
</Shell>
