---
import Shell from '../components/Shell.astro';
import AnalyzeCompetitorsContainer from '../components/compare/AnalyzeCompetitorsContainer';
import VisualStage from '../components/VisualStage.astro';
import { marketingVisuals } from '../lib/marketingVisuals';
---

<Shell
  title="Competitor AI Visibility Analysis — GEO Optimizer"
  description="Analyze competitor AI visibility with GEO Optimizer. Compare multiple websites across GEO scores, citability, technical readiness, and AI search signals."
  canonical="https://geoready.dev/analyze-competitors/"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 py-10 md:py-16">
    {/* Static hero — visible to crawlers */}
    <header class="mb-8 overflow-hidden rounded-[--radius-2xl] border border-white/10 bg-bg-dark text-text-inverse shadow-[0_36px_100px_-70px_rgba(15,23,42,0.9)] md:mb-10">
      <div class="relative grid gap-0 lg:grid-cols-[minmax(0,0.86fr)_minmax(420px,0.82fr)]">
        <div
          aria-hidden="true"
          class="absolute inset-0 opacity-45"
          style="background-image: radial-gradient(circle at 76% 24%, rgba(94,234,212,0.18), transparent 34%), linear-gradient(rgba(148,163,184,0.08) 1px, transparent 1px), linear-gradient(90deg, rgba(148,163,184,0.08) 1px, transparent 1px); background-size: auto, 52px 52px, 52px 52px;"
        />
      <div class="relative p-6 md:p-10 lg:p-12">
        <div class="flex items-center gap-2 text-[10px] font-mono text-slate-300 uppercase tracking-wider">
          <span>GEO Optimizer</span>
          <span class="w-1 h-1 rounded-full bg-slate-500" />
          <span>Competitors</span>
        </div>

        <h1 class="mt-4 max-w-3xl font-display text-4xl md:text-5xl font-bold leading-tight tracking-tight">
          Map the competitors that AI engines are most ready to cite.
        </h1>

        <p class="mt-5 text-base md:text-lg text-text-muted leading-relaxed max-w-2xl">
          Enter multiple competitor URLs and run a batch GEO audit. See how each site scores for AI search visibility, citability, and technical readiness.
        </p>

        <div class="mt-8 grid gap-3 sm:grid-cols-3">
          {[
            ['Portfolio', 'Multiple domains in one run.'],
            ['Pattern', 'Shared blockers and winning signals.'],
            ['Priority', 'Where to focus before the next audit.'],
          ].map(([label, text]) => (
            <div class="border-l border-teal-300/40 pl-4">
              <p class="font-mono text-[11px] uppercase tracking-[0.16em] text-teal-100">{label}</p>
              <p class="mt-1 text-sm leading-relaxed text-text-muted">{text}</p>
            </div>
          ))}
        </div>

        <p class="mt-8 text-xs text-text-muted font-mono">Last updated: May 2026</p>
      </div>

      <div class="relative border-t border-white/10 p-4 lg:border-l lg:border-t-0">
        <VisualStage
          visual={marketingVisuals.commandCenter}
          variant="dark"
          label="Competitor map"
          eyebrow="Batch audit"
          sizes="(min-width: 1024px) 40vw, 100vw"
          loading="eager"
          priority
          imgClass="aspect-[16/9] object-cover"
          metrics={[
            { label: 'Mode', value: 'Batch' },
            { label: 'Scope', value: 'Many URLs' },
            { label: 'Output', value: 'Ranked gaps' },
          ]}
          chips={['GEO score', 'Citability', 'Signal spread']}
        />
      </div>
      </div>
    </header>

    {/* Static info section — visible to crawlers */}
    <section class="mb-10 grid gap-4 rounded-[--radius-xl] border border-border bg-bg-surface p-5 md:grid-cols-[minmax(0,0.46fr)_repeat(3,minmax(0,1fr))] md:p-6">
      <div>
        <h2 class="text-sm font-mono font-semibold uppercase tracking-wider text-accent-teal">
          What competitor analysis checks
        </h2>
        <p class="mt-3 text-sm text-text-secondary leading-relaxed">
          Every competitor is scored across the same categories so relative strengths are visible.
        </p>
      </div>
      {[
        ['Score', 'GEO Score across 8 signal categories.'],
        ['Citability', 'Citation-oriented content and source signals.'],
        ['Readiness', 'Technical access, structure, and AI discovery.'],
      ].map(([label, text]) => (
        <div class="border-l border-border pl-4">
          <p class="font-display text-base font-semibold text-text-primary">{label}</p>
          <p class="mt-2 text-sm leading-relaxed text-text-secondary">{text}</p>
        </div>
      ))}
      <p class="text-sm text-text-secondary md:col-start-2 md:col-span-3">
        Need a focused two-site benchmark? <a href="/compare/" class="text-accent-teal hover:underline">Use side-by-side comparison</a>.
      </p>
    </section>

    {/* Interactive tool — hydrated by React */}
    <AnalyzeCompetitorsContainer client:only="react" />
  </div>

  {/* Page-specific schema */}
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Competitor AI Visibility Analysis — GEO Optimizer",
    "description": "Analyze competitor AI visibility with GEO Optimizer. Compare multiple websites across GEO scores, citability, technical readiness, and AI search signals.",
    "url": "https://geoready.dev/analyze-competitors/",
    "author": {
      "@type": "Organization",
      "name": "Auriti Labs",
      "url": "https://github.com/Auriti-Labs"
    },
    "publisher": {
      "@type": "Organization",
      "name": "Auriti Labs",
      "url": "https://github.com/Auriti-Labs"
    },
    "datePublished": "2026-05-12",
    "dateModified": "2026-05-26",
    "mainEntity": {
      "@type": "WebApplication",
      "name": "GEO Optimizer Competitor Analysis Tool",
      "applicationCategory": "DeveloperApplication",
      "operatingSystem": "Web",
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "USD"
      },
      "featureList": [
        "Batch competitor GEO audit",
        "Citability benchmarking",
        "Technical signal comparison",
        "AI visibility scoring"
      ]
    }
  })} />
</Shell>
