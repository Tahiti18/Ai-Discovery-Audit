---
import Shell from '../../components/Shell.astro';
import AICitationChecker from '../../components/tools/AICitationChecker';
import VisualStage from '../../components/VisualStage.astro';
import { marketingVisuals } from '../../lib/marketingVisuals';

// Metadati SEO della pagina del tool.
const title = 'Free AI Citation Checker — Is Your Brand Cited by ChatGPT & Perplexity?';
const description =
  'Ask real AI answer engines the questions your customers ask and see whether your brand is mentioned and your domain is cited as a source — or who gets cited instead of you.';
const canonical = 'https://geoready.dev/tools/ai-citation-checker/';

// FAQ visibili — riusate sia nel markup crawlable che nello schema FAQPage.
const faqs = [
  {
    question: 'How does the AI citation checker work?',
    answer:
      'It sends customer-style questions about your product category to Perplexity Sonar, an AI answer engine grounded in live web search, and analyzes the answers: is your brand mentioned in the text, and does your domain appear among the cited sources? You also see which competitor domains were cited instead of you.',
  },
  {
    question: 'Why Perplexity and not ChatGPT?',
    answer:
      'Perplexity grounds every answer in a live web search and returns the exact source URLs it cited, which makes citations verifiable. ChatGPT and other parametric models do not expose their sources the same way. Citation patterns correlate across engines: if your content is citable for Perplexity, you are building the same signals other AI engines reward.',
  },
  {
    question: 'What does "mentioned but not cited" mean?',
    answer:
      'The AI knows your brand — usually from third-party pages like reviews or directories — but never cites your own domain as a source. That means other sites are the reference for your own product. The fix is making your own pages the citable source: structured data, llms.txt, statistics, and quotable content.',
  },
  {
    question: 'How often do AI citations change?',
    answer:
      'Continuously. AI answers are regenerated for every query and the underlying indexes refresh constantly, so a brand cited today can silently disappear next week. A one-shot check is a snapshot; ongoing monitoring is how you catch losses early.',
  },
  {
    question: 'Is this check really free?',
    answer:
      'Yes. Each check asks the AI engine two questions at our expense, so there is a fair-use limit per visitor and per day. For scheduled checks, more queries, history, and alerts, GeoReady plans start at $19/month.',
  },
];
---

<Shell title={title} description={description} canonical={canonical}>
  <article class="px-4 sm:px-6 py-10 md:py-16">
    {/* Header con breadcrumb eyebrow */}
    <header class="mx-auto mb-10 max-w-7xl overflow-hidden rounded-[--radius-2xl] border border-border bg-bg-surface md:mb-12">
      <div class="grid lg:grid-cols-[minmax(0,0.88fr)_minmax(420px,0.82fr)]">
      <div class="p-6 md:p-10 lg:p-12">
        <div class="flex items-center gap-2 text-[10px] font-mono text-text-muted uppercase tracking-wider">
          <a href="/" class="hover:text-accent-teal">Tools</a>
          <span class="w-1 h-1 rounded-full bg-text-muted" />
          <span>AI citation checker</span>
        </div>

        <h1 class="mt-4 max-w-3xl font-display text-4xl md:text-5xl font-bold text-text-primary leading-tight tracking-tight">
          See whether AI answers cite you or send trust somewhere else.
        </h1>

        {/* Intro answer-first: cosa fa il tool. */}
        <p class="mt-5 max-w-2xl text-base md:text-lg text-text-secondary leading-relaxed">
          When your customers ask an AI engine "what's the best tool for…", does the
          answer mention <em>your</em> brand and cite <em>your</em> domain — or a
          competitor's? This tool asks a real AI answer engine and shows you the
          verdict, with the actual sources the AI cited.
        </p>

        <div class="mt-8 grid gap-3 sm:grid-cols-3">
          {[
            ['Ask', 'Customer-style category prompts.'],
            ['Trace', 'Returned sources and cited domains.'],
            ['Act', 'Verdicts that point to the next fix.'],
          ].map(([label, text]) => (
            <div class="border-l border-accent-teal/30 pl-4">
              <p class="font-mono text-[11px] uppercase tracking-[0.16em] text-accent-teal">{label}</p>
              <p class="mt-1 text-sm leading-relaxed text-text-secondary">{text}</p>
            </div>
          ))}
        </div>
      </div>

      <div class="border-t border-border bg-bg-subtle p-4 lg:border-l lg:border-t-0">
        <VisualStage
          visual={marketingVisuals.citationChecker}
          variant="paper"
          label="Citation intelligence"
          eyebrow="Checker"
          sizes="(min-width: 1024px) 38vw, 100vw"
          loading="eager"
          priority
          imgClass="aspect-[3/2] object-cover"
          metrics={[
            { label: 'Question', value: 'Buyer prompt' },
            { label: 'Evidence', value: 'Cited URLs' },
            { label: 'Verdict', value: 'Mention + cite' },
          ]}
          chips={['Brand mention', 'Domain citation', 'Competitor sources']}
        />
      </div>
      </div>
    </header>

    {/* ── Isola React: il checker vero e proprio ──────────────────────────── */}
    <section class="mx-auto mb-14 max-w-5xl md:mb-16" aria-labelledby="citation-tool-heading">
      <div class="mb-5 flex flex-col gap-2 md:flex-row md:items-end md:justify-between">
        <div>
          <p class="font-mono text-[11px] uppercase tracking-[0.18em] text-accent-teal">Tool workspace</p>
          <h2 id="citation-tool-heading" class="mt-2 font-display text-2xl font-bold text-text-primary">Run a citation check</h2>
        </div>
        <p class="max-w-md text-sm leading-relaxed text-text-secondary">
          Test a brand, domain, and category against source-backed AI answers.
        </p>
      </div>
      <div class="rounded-[--radius-xl] border border-border bg-bg-surface p-3 shadow-[0_24px_80px_-60px_rgba(15,23,42,0.55)] sm:p-4">
        <AICitationChecker client:load />
      </div>
    </section>

    {/* ── Contenuto SEO statico e crawlable ───────────────────────────────── */}
    <div class="max-w-3xl mx-auto space-y-12 md:space-y-16 [&_h2]:font-display [&_h2]:text-2xl [&_h2]:font-bold [&_h2]:text-text-primary [&_h2]:leading-tight [&_h2]:tracking-tight [&_h3]:font-display [&_h3]:text-lg [&_h3]:font-semibold [&_h3]:text-text-primary [&_p]:text-text-secondary [&_p]:leading-relaxed [&_li]:text-text-secondary [&_li]:leading-relaxed">

      <section>
        <h2>Why AI citations matter more than rankings</h2>
        <p class="mt-4">
          AI answer engines don't show ten blue links — they give one answer and
          cite a handful of sources. If your domain is among those sources, you
          capture the click and the trust. If it isn't, the AI is actively
          sending your customers to whoever <em>is</em> cited. Ahrefs found that
          28.3% of ChatGPT's most-cited pages have zero organic visibility on
          Google: AI citation is a different game from classic SEO, with
          different winners.
        </p>
      </section>

      <section>
        <h2>What the four verdicts mean</h2>
        <ul class="mt-4 space-y-3 list-disc pl-5">
          <li><strong>🏆 Strong</strong> — your domain is cited as a source in most answers. Monitor it: positions degrade silently.</li>
          <li><strong>✅ Cited</strong> — you appear among sources, but not consistently. Strengthen citability to win more answers.</li>
          <li><strong>🟡 Mentioned only</strong> — the AI knows your brand from third parties but never cites your own pages. Make your domain the reference.</li>
          <li><strong>❌ Invisible</strong> — neither mentioned nor cited. Start with a <a href="/" class="text-accent-teal hover:underline">free GEO audit</a> and fix the high-impact items first.</li>
        </ul>
      </section>

      <section>
        <h2>How to improve your AI citations</h2>
        <p class="mt-4">
          Citations are earned with technical and content signals that AI
          retrieval rewards: open access for AI crawlers, structured data,
          an <a href="/tools/llms-txt-generator/" class="text-accent-teal hover:underline">llms.txt</a>,
          quotable statistics, and multi-page topical coverage. The
          {' '}<a href="/guides/generative-engine-optimization/" class="text-accent-teal hover:underline">GEO guide</a>{' '}
          covers the full playbook, and the free audit scores your site on 100
          points across 8 categories. Run the audit, fix the priority items,
          then come back and re-check your citations.
        </p>
      </section>

      {/* FAQ visibili (stesse del FAQPage schema) */}
      <section>
        <h2>Frequently asked questions</h2>
        <div class="mt-6 space-y-6">
          {faqs.map((faq) => (
            <div>
              <h3>{faq.question}</h3>
              <p class="mt-2">{faq.answer}</p>
            </div>
          ))}
        </div>
      </section>

      {/* CTA finale → SaaS */}
      <section>
        <h2>One check is a snapshot. Tracking is the moat.</h2>
        <p class="mt-4">
          AI answers change every week. GeoReady runs your citation checks on a
          schedule, alerts you when you lose or win a citation, and shows who
          replaced you — so you act before the traffic moves.
        </p>
        <div class="mt-6 flex flex-wrap gap-3">
          <a
            href="https://app.geoready.dev/signup?utm_source=citation-checker-page&intent=citations"
            class="inline-flex items-center justify-center rounded-full bg-accent-teal px-6 py-3 text-sm font-semibold text-white transition-opacity hover:opacity-90"
          >
            Start tracking citations
          </a>
          <a
            href="/pricing/"
            class="inline-flex items-center justify-center rounded-full border border-border px-6 py-3 text-sm font-medium text-text-primary transition-colors hover:border-accent-teal"
          >
            See pricing
          </a>
        </div>
      </section>
    </div>
  </article>

  {/* Schema JSON-LD: WebApplication (il tool) + FAQPage (le stesse FAQ visibili). */}
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "WebApplication",
        "name": "Free AI Citation Checker",
        "applicationCategory": "DeveloperApplication",
        "operatingSystem": "Any",
        "url": canonical,
        "description": description,
        "offers": {
          "@type": "Offer",
          "price": "0",
          "priceCurrency": "USD"
        },
        "publisher": {
          "@type": "Organization",
          "name": "Auriti Labs",
          "url": "https://github.com/Auriti-Labs"
        }
      },
      {
        "@type": "FAQPage",
        "mainEntity": faqs.map((faq) => ({
          "@type": "Question",
          "name": faq.question,
          "acceptedAnswer": {
            "@type": "Answer",
            "text": faq.answer
          }
        }))
      }
    ]
  })} />
</Shell>
