# frontend/.env — copy to `.env` for local dev. Values prefixed PUBLIC_ are
# baked into the client bundle at BUILD time (set them in Railway's service
# variables so `npm run build` sees them).

# Where the browser reaches the platform API.
#   local dev:   http://localhost:8001
#   production:  https://api.visibletoai.io
PUBLIC_PLATFORM_API_BASE=http://localhost:8001
