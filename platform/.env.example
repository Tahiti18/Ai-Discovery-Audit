# GeoReady Platform — environment configuration (Phase 0)
# Copy to .env and adjust. NEVER commit real secrets.

# ── Database ──────────────────────────────────────────────────────────────────
# Local dev defaults to SQLite. Production uses Postgres:
#   GR_DATABASE_URL=postgresql+psycopg://geoready:geoready@localhost:5432/geoready
GR_DATABASE_URL=sqlite:///./geoready_platform.db

# ── Cache / Celery broker ─────────────────────────────────────────────────────
GR_REDIS_URL=redis://localhost:6379/0

# ── Auth ──────────────────────────────────────────────────────────────────────
# MUST be set to a strong random value in production.
GR_JWT_SECRET=dev-insecure-change-me
GR_JWT_ALG=HS256
GR_JWT_TTL_SECONDS=3600

# ── Worker execution ──────────────────────────────────────────────────────────
# true  -> Celery runs tasks inline (no broker needed; dev/test/single-process)
# false -> real workers consume from Redis (production)
GR_CELERY_EAGER=false
GR_AUDIT_TIMEOUT_SECONDS=60

# ── Quotas ────────────────────────────────────────────────────────────────────
GR_FREE_AUDITS_PER_DAY=5

# ── AI provider keys ──────────────────────────────────────────────────────────
# OpenRouter recommended (one key, web-grounded Perplexity for the probe).
OPENROUTER_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
PERPLEXITY_API_KEY=

# ── Auth / magic-link ─────────────────────────────────────────────────────────
# Frontend base URL used to build sign-in links. Production: https://visibletoai.io
GR_APP_BASE_URL=http://localhost:4321
# Transactional email (Resend). Setting RESEND_API_KEY enables real emails;
# without it, dev returns the sign-in link on-page (localhost only — off-local
# the link is only logged server-side, never returned).
RESEND_API_KEY=
GR_EMAIL_FROM=Visible to AI <signin@visibletoai.io>

# ── Production hardening ──────────────────────────────────────────────────────
# Comma-separated allowed origins. Production: https://visibletoai.io
GR_CORS_ORIGINS=*
# The API REFUSES to start off-localhost while GR_JWT_SECRET is the dev default.

# ── Stripe billing ────────────────────────────────────────────────────────────
# Dashboard → Developers → API keys (use test keys to start).
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
# `stripe listen --forward-to localhost:8001/v1/billing/webhook` (local) or the
# webhook endpoint's signing secret (deployed).
STRIPE_WEBHOOK_SECRET=
# Price IDs (price_...) created under Stripe → Products.
STRIPE_PRICE_PRO=
STRIPE_PRICE_FOUNDING=
STRIPE_PRICE_BUSINESS=
